<% layout("layouts/boilerplate") %>
<script>
const mapToken = "<%= process.env.MAP_TOKEN %>";

const listing = <%- JSON.stringify(listing)%>;

console.log("EJS Coordinates:", listing.geometry.coordinates);
</script>

  <div class="container py-4">

    <!-- ===== Title ===== -->
    <div class="row mb-3">
      <div class="col-lg-6 mx-auto">
        <h2 class="fw-semibold mb-1"><%= listing.title %></h2>
        <p class="text-muted mb-0">
          <%= listing.location %>, <%= listing.country %>
        </p>
      </div>
    </div>

  <!-- ===== Image + Details ===== -->
<div class="row mb-4">
  <div class="col-lg-6 mx-auto">
    <div class="card show-card">
          
          <img src="<%= listing.image.url %>" class="card-img-top show-img mb-2" alt="listing image"> 

          <div class="card-body p-3">
            <p>Owned by  <i><%=listing.owner.username%></i></p>
            <p class="mb-2"><%= listing.description %></p>

            <h5 class="price-amount mb-0">
              &#8377; <%= listing.price.toLocaleString("en-IN") %>
              <span class="text-muted fs-6"> / night</span>
            </h5>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== Action Buttons ===== -->
     <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
    <div class="row mb-5">
      <div class="col-lg-6 mx-auto d-flex gap-2">

        <a href="/listings/<%= listing._id %>/edit"
           class="btn btn-dark edit-btn">
          Edit
        </a>

        <form action="/listings/<%= listing._id %>?_method=DELETE"
              method="POST">
          <button class="btn btn-dark delete-btn">
            Delete
          </button>
        </form>

      </div>
    </div>
  <%}%>

    <!-- ===== Review Form ===== -->
    <div class="row mb-4">
      <% if(currUser) {%>
      <div class="col-lg-6 mx-auto">

        <h4 class="mb-3">Leave a Review</h4>

        <div class="p-3 rounded-4 ">

          <form action="/listings/<%= listing._id %>/reviews"
                method="POST"
                novalidate
                class="needs-validation">

            <div class=" mb-1">
            <fieldset class="starability-slot">

             <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating."/>

               <input type="radio" id="first-rate1" name="review[rating]" value="1" />
               <label for="first-rate1" title="Terrible">1 star</label>
               <input type="radio" id="first-rate2" name="review[rating]" value="2" />
               <label for="first-rate2" title="Not good">2 stars</label>
               <input type="radio" id="first-rate3" name="review[rating]" value="3" />
               <label for="first-rate3" title="Average">3 stars</label>
               <input type="radio" id="first-rate4" name="review[rating]" value="4" />
               <label for="first-rate4" title="Very good">4 stars</label>
               <input type="radio" id="first-rate5" name="review[rating]" value="5" />
               <label for="first-rate5" title="Amazing">5 stars</label>
  
               </fieldset>
              </div>
            
              <div class="mb-3">
              <label for="comment" class="form-label">Comments</label>
              <textarea
                name="review[comment]"
                id="comment"
                rows="4"
                class="form-control"
                required></textarea>
              <div class="invalid-feedback">
                Please submit some comments for review
              </div>
            </div>

            <% if(currUser && !currUser._id.equals(listing.owner._id)) {%>
            <button class="btn btn-dark">
              Submit Review
            </button>
            <%}%>

          </form>
        </div>
      </div>
    </div>
    <% } %>
  
<div class="row">
  <div class="col-lg-6 mx-auto">

    <%if(listing.reviews && listing.reviews.length>0){%>
    <h4 class="mb-3">All Reviews</h4>

    <div class="row g-3">

      <% for (let review of listing.reviews) { %>

        <div class="col-md-6">
          <div class="card review-card h-100">
            <div class="card-body">

              <h6 class="fw-semibold mb-1"><%=review.author.username%></h6>
              <p class="starability-result card-text" data-rating=<%=review.rating%>></p>
              <p class="card-text mb-2"><%= review.comment %> </p>
               
              <% if(currUser && (currUser._id.equals(review.author._id) || currUser._id.equals(listing.owner._id))) { %>
              <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST">
              <button class="btn btn-sm btn-dark">Delete</button>
               </form>
              <% } %>
            
            </div>
          </div>
        </div>

      <% } %>

    </div>
  <%}%>

    <div class="col-12 col-md-8 mx-auto mb-3">
  <h3>Where you'll be</h3>
  <div id="map"></div>
</div>
  
  </div>
</div>
  </div>

  <script src="/js/map.js"></script>