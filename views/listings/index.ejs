<% layout("layouts/boilerplate") %>

<body>

<style>
/* ===== FILTER BAR ===== */
.filters-bar{
  display: flex;
  justify-content: space-evenly;
  gap: 1rem;
  margin-top: 1rem;
}

/* ===== SCROLLABLE FILTERS ===== */
#filters{
  display: flex;
  gap: 2rem;
  overflow-x: auto;
  white-space: nowrap;
  flex: 1;
  scrollbar-width: none;
}
#filters::-webkit-scrollbar{
  display: none;
}

/* ===== FILTER ITEM ===== */
.filter{
  flex: 0 0 auto;
  width: 70px;
  text-align: center;
  opacity: 0.7;
  text-decoration: none;
  color: #222222;
}
.filter:hover{
  opacity: 1;
  cursor: pointer;
}
.filter p{
  font-size: 0.75rem;
}

.font{
  font-size: 0.9rem;
}
/* ===== TOGGLE RIGHT SIDE ===== */
.tax-toggle{
  flex-shrink: 0;
  margin-left: 0.3rem;
}

/* ===== PILL ===== */
.tax-pill{
  display: flex;
  
  gap: 10px;

  border: 1px solid #ddd;
  padding: 8px 16px;
  border-radius: 30px;
  background: white;
  
  height: 40px;
}

/* ===== CUSTOM SWITCH ===== */
.tax-pill input{
  appearance: none;
  width: 38px;
  height: 20px;
  background: #ccc;
  border-radius: 50px;
  position: relative;
  cursor: pointer;
  outline: none;
  transition: 0.3s;
}

.tax-pill input::before{
  content: "";
  position: absolute;
  width: 16px;
  height: 16px;
  background: white;
  border-radius: 50%;
  top: 2px;
  left: 2px;
  transition: 0.3s;
}

.tax-pill input:checked{
  background: #fe424d;
}

.tax-pill input:checked::before{
  transform: translateX(18px);
}

/* LABEL */
.tax-pill label{
  font-size: 0.9rem;
  margin: 0;
  cursor: pointer;
}
/* ===== RESPONSIVE FILTER BAR ===== */
@media (max-width: 768px){

  .filters-bar{
    flex-direction: column;      /* stack */
    align-items: stretch;
    gap: 10px;
  }

  /* FILTERS SCROLL FULL WIDTH */
  #filters{
    width: 100%;
    overflow-x: auto;
    padding-bottom: 5px;
  }

  /* TOGGLE FULL WIDTH */
  .tax-toggle{
    width: 100%;
  }

  .tax-pill{
    width: 100%;
    justify-content: space-between;   /* text left, toggle right */
  }

  .tax-pill label{
    font-size: 0.85rem;
  }
}
</style>

<!-- ===== FILTER BAR ===== -->
<div class="filters-bar">

  <!-- FILTERS -->
  <div id="filters">

  
      <a href="/listings/category?category=Trending" class="filter">
      <i class="fa-solid fa-fire"></i><p>Trending</p>
      </a>

      <a href="/listings/category?category=Rooms" class="filter">
      <i class="fa-solid fa-bed"></i><p>Rooms</p>
      </a>

      <a href="/listings/category?category=IconicCities" class="filter">
      <i class="fa-solid fa-city"></i><p>IconicCities</p>
      </a>

      <a href="/listings/category?category=Mountains" class="filter">
      <i class="fa-solid fa-mountain"></i><p>Mountains</p>
      </a>

      <a href="/listings/category?category=Castles" class="filter">
      <i class="fa-brands fa-fort-awesome"></i><p>Castles</p>
      </a>
    
      <a href="/listings/category?category=Amazing%20Pools" class="filter">
      <i class="fa-solid fa-person-swimming"></i><p>Amazing Pools</p>
      </a>

      <a href="/listings/category?category=Camping" class="filter">
      <i class="fa-solid fa-campground"></i><p>Camping</p>
      </a>

      <a href="/listings/category?category=Farms" class="filter">
      <i class="fa-solid fa-cow"></i><p>Farms</p>
      </a>

      <a href="/listings/category?category=Arctic" class="filter">
      <i class="fa-regular fa-snowflake"></i><p>Arctic</p>
      </a>

  </div>

  <!-- TOGGLE (CUSTOM - NO BOOTSTRAP BUGS) -->
  <div class="tax-toggle">
    <div class="tax-pill">
      <input type="checkbox" id="switchCheckDefault">
      <label for="switchCheckDefault"><p class="font">Display total after taxes</p></label>
    </div>
  </div>

</div>

<!-- ===== LISTINGS ===== -->
<div class="container mt-4">

  <h3 class="mb-4 fw-semibold">Explore Listings</h3>

  <div class="row g-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

    <% for(let listing of allListings){ %>

      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">

          <div class="card listing-card h-100 shadow-sm">

            <!-- Image -->
            <div class="listing-img-wrapper">
              <img
                src="<%= listing.image.url %>"
                class="card-img-top listing-img"
              >
            </div>

            <!-- Body -->
            <div class="card-body">

              <h5 class="card-title listing-title">
                <%= listing.title %>
              </h5>

              <p class="listing-location text-muted mb-2">
                <%= listing.location %>, <%= listing.country %>
              </p>

              <p class="listing-price mb-0">
                <span class="price-amount">
                  ₹ <%= listing.price.toLocaleString("en-IN") %>
                  <i class="tax-info"> +18% GST</i>
                </span>
                <span class="text-muted"> / night</span>
              </p>

            </div>

          </div>

        </a>
      </div>

    <% } %>

  </div>
</div>

<!-- ===== SCRIPT ===== -->
<script>
const taxSwitch = document.getElementById("switchCheckDefault");

taxSwitch.addEventListener("change", () => {
  const taxInfo = document.getElementsByClassName("tax-info");

  for(let info of taxInfo){
    info.style.display = taxSwitch.checked ? "inline" : "none";
  }
});
</script>

</body>